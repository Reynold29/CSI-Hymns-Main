# Uncomment this line to define a global platform for your project
platform :ios, '13.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

target 'OneSignalNotificationServiceExtension' do
  use_frameworks!
  use_modular_headers!
  pod 'OneSignalXCFramework', '>= 5.0.0', '< 6.0.0'
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
  end

  # Fix Xcode build phase cycle caused by adding OneSignalNotificationServiceExtension.
  # Moves "[CP] Embed Pods Frameworks" before "Thin Binary" in the Runner target's
  # build phases to break the circular dependency introduced by the app extension.
  installer.aggregate_targets.each do |aggregate_target|
    aggregate_target.user_project.native_targets.each do |native_target|
      next unless native_target.name == 'Runner'
      phases = native_target.build_phases
      embed_phase = phases.find { |bp| bp.respond_to?(:name) && bp.name == '[CP] Embed Pods Frameworks' }
      thin_phase  = phases.find { |bp| bp.respond_to?(:name) && bp.name == 'Thin Binary' }
      next unless embed_phase && thin_phase
      embed_idx = phases.index(embed_phase)
      thin_idx  = phases.index(thin_phase)
      if embed_idx > thin_idx
        phases.delete(embed_phase)
        phases.insert(thin_idx, embed_phase)
      end
    end
    aggregate_target.user_project.save
  end

  # Fix CocoaPods warning about CLANG_WARN_QUOTED_INCLUDE_IN_FRAMEWORK_HEADER
  # being overridden in the OneSignalNotificationServiceExtension target in Runner.xcodeproj.
  installer.aggregate_targets.each do |aggregate_target|
    aggregate_target.user_project.native_targets.each do |native_target|
      next unless native_target.name == 'OneSignalNotificationServiceExtension'
      native_target.build_configurations.each do |config|
        config.build_settings.delete('CLANG_WARN_QUOTED_INCLUDE_IN_FRAMEWORK_HEADER')
      end
    end
    aggregate_target.user_project.save
  end
end
